# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenRouter model IDs. Swap freely; these are sensible defaults.
FAST_MODEL=anthropic/claude-haiku-4-5
SMART_MODEL=anthropic/claude-opus-4-7

# Google OAuth (Desktop app credentials) — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Obtained by running: uv run python -m assistant_backend.bootstrap_google_auth
GOOGLE_REFRESH_TOKEN=

PORT=8000
